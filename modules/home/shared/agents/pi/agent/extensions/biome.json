{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"formatter": {
		"lineWidth": 80
	},
	"linter": {
		"rules": {
			"recommended": true,
			"style": {
				"noDefaultExport": "off",
				"useBlockStatements": "error"
			},
			"nursery": {
				"useDestructuring": "error",
				"useExplicitReturnType": "error",
				"useUnicodeRegex": "error",
				"noShadow": "error"
			}
		}
	}
}
